# ╔══════════════════════════════════════════════════════╗
# ║  Samuell Goldfinch — Environment Variables          ║
# ║  Copy to .env and fill in real values               ║
# ╚══════════════════════════════════════════════════════╝

# ── Server-side only (never exposed to browser) ──────

# MongoDB Atlas — Payload CMS database
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Payload CMS — secret key for auth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=generate-a-64-char-random-string

# Cloudinary — image hosting & optimization (server-side upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Mux — video streaming (server-side asset management)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Resend — transactional email
RESEND_API_KEY=re_your-resend-key

# ── Public (NEXT_PUBLIC_* — exposed to browser) ──────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://samuellgoldfinch.com

# Cloudinary cloud name (for image URLs)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Meta Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
