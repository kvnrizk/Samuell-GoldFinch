# MongoDB Atlas — Payload CMS database
DATABASE_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sg-platform?retryWrites=true&w=majority

# Payload CMS — secret key for auth tokens (generate 32+ random chars)
PAYLOAD_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# Cloudinary — image hosting & optimization
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mux — video streaming
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret

# Resend — transactional email
RESEND_API_KEY=re_xxxxxxxxxxxx

# Public
NEXT_PUBLIC_SITE_URL=https://samuellgoldfinch.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
