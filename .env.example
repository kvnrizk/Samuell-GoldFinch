# Samuell Goldfinch - Environment Variables
# Copy this file to `.env` and fill in real values.

# Server-side only. Never expose these in browser code.

# Payload CMS database.
# Production should use MongoDB Atlas.
# Local dev can use a local MongoDB if installed:
# DATABASE_URI=mongodb://127.0.0.1:27017/sg-platform?serverSelectionTimeoutMS=1000
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Payload CMS auth token signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=generate-a-64-char-random-string

# Cloudinary image hosting and optimization.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Mux video streaming.
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Resend transactional email.
RESEND_API_KEY=re_your-resend-key

# Optional server-side settings.

# Admin panel protection. Leave empty to disable locally.
# ADMIN_ACCESS_SECRET=your-secret-here

# Automation cron protection for /api/cron/process-sequences.
# CRON_SECRET=generate-a-random-secret

# Notification fallback if Global Settings has no WhatsApp number.
# SAM_WHATSAPP_NUMBER=+33605883966

# Seed script credentials. Only needed for `npm run seed`.
# PAYLOAD_ADMIN_EMAIL=admin@samuellgoldfinch.com
# PAYLOAD_ADMIN_PASSWORD=your-admin-password

# Public variables. NEXT_PUBLIC_* values are exposed to browser code.

# Site URL. Use http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=https://samuellgoldfinch.com

# Cloudinary cloud name for public image URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Optional analytics IDs.
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
